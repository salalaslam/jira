# Provisioned by `npx convex dev` — local: `.env.local`, prod on Vercel as env var.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Only used by `pnpm seed` to create/update Thomas and Salal accounts.
THOMAS_PASSWORD=change-me
SALAL_PASSWORD=change-me

# MinIO (set in the Convex dashboard — not in Vercel)
# MINIO_ENDPOINT=https://<your-minio-host>
# MINIO_PUBLIC_URL=https://<your-minio-host>
# MINIO_ACCESS_KEY=your-minio-access-key
# MINIO_SECRET_KEY=your-minio-secret-key
# MINIO_BUCKET=<your-bucket>
